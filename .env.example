# openrate — optional paid source API keys.
# Copy to .env and fill in any you have. Each paid source AUTO-ENABLES when its
# key is present — no need to add it to -sources. Leave blank to skip.
# The free sources (ecb, coinbase, luno, sarb, …) need no keys.

# Open Exchange Rates — https://openexchangerates.org  (free tier hourly; ~$12/mo for 60s)
OPENRATE_OXR_APP_ID=

# Twelve Data — https://twelvedata.com  (free tier 800 req/day, real-time FX)
OPENRATE_TWELVEDATA_KEY=

# Polygon.io — https://polygon.io  (real-time FX snapshot + WebSocket)
OPENRATE_POLYGON_KEY=

# TraderMade — https://tradermade.com  (FX-specialist live quotes; free 1k/mo)
OPENRATE_TRADERMADE_KEY=

# ── interest rates (separate engine; /api/v1/interest/*) ──
# FRED — https://fred.stlouisfed.org/docs/api/api_key.html  (free key)
# Auto-enables the `fred` interest source: US SOFR/EFFR/prime/Treasury series.
OPENRATE_FRED_API_KEY=

# ── engine config (optional; flags also work) ──
# OPENRATE_ADDR=:8080
# OPENRATE_BASE=ZAR
# OPENRATE_REFRESH=5m
# OPENRATE_SOURCES=ecb,coinbase,luno,sarb,erapi,fawazahmed0,boc
# OPENRATE_RATELIMIT=120
# Interest-rate sources (default: bis,sarbrates; fred auto-enables with its key):
# OPENRATE_INTEREST_SOURCES=bis,sarbrates,fred
# OPENRATE_INTEREST_REFRESH=6h
# OPENRATE_BIS_HISTORY=90      # daily observations of policy-rate history per country
# OPENRATE_FRED_HISTORY=120
